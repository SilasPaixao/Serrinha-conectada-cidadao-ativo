generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")  // Pooler aqui
  directUrl = env("DIRECT_URL")    // Direct aqui (migrations)
}

enum UserRole {
  CITIZEN
  GOVERNMENT
  ADMIN
}

enum IssueStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  role          UserRole  @default(CITIZEN)
  status        UserStatus @default(ACTIVE)
  whatsapp      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  issues        Issue[]
  statusChanges IssueStatusHistory[]
}

model Issue {
  id            String               @id @default(uuid())
  protocol      String               @unique
  category      String
  description   String
  latitude      Float
  longitude     Float
  address       String?
  reporterEmail String?
  whatsapp      String?
  imageUrl      String?
  status        IssueStatus          @default(PENDING)
  userId        String?
  user          User?                @relation(fields: [userId], references: [id])
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  history       IssueStatusHistory[]
}

model WhatsAppLog {
  id          String    @id @default(uuid())
  issueId     String?
  phoneNumber String
  message     String
  status      String    // pending, sent, failed
  lastError   String?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  sentAt      DateTime?
}

model IssueStatusHistory {
  id          String      @id @default(uuid())
  issueId     String
  issue       Issue       @relation(fields: [issueId], references: [id])
  status      IssueStatus
  comment     String?
  changedById String
  changedBy   User        @relation(fields: [changedById], references: [id])
  createdAt   DateTime    @default(now())
}
